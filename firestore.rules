rules_version = '2';

// ============================================================================
// Firestore Security Rules — Plodpai Alert
//
// หลักการ: แยกข้อมูลเป็น 2 ชั้นชัดเจน
//   1) คอลเลกชันที่มีข้อมูลส่วนบุคคล (ชื่อ, เบอร์โทร, พิกัดผูกกับตัวบุคคล)
//      → "อ่าน" ได้เฉพาะผู้ที่ล็อกอินแล้วเท่านั้น (Admin/หน่วยกู้ภัย ผ่านหน้า admin.html)
//      → "เขียน/สร้าง" ยังเปิดให้สาธารณะทำได้ เพราะผู้ประสบภัยต้องส่งคำขอได้โดยไม่ต้องสมัครสมาชิก
//   2) คอลเลกชันสาธารณะ (public_pins, zone_state, quake_events) ไม่มี PII ติดอยู่เลย
//      → เปิดอ่าน/เขียนได้แบบสาธารณะ ใช้แสดงผลใน dashboard.html (หน้าสาธารณะ)
//
// ก่อน deploy ใช้งานจริงกับสาธารณะในวงกว้าง แนะนำเพิ่ม Firebase App Check
// เพื่อป้องกัน bot/สคริปต์ยิง request ปลอมเข้าคอลเลกชันสาธารณะ
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- คำขอ SOS (มีชื่อ/เบอร์โทร) -----
    match /sos_alerts/{id} {
      allow read: if request.auth != null; // เฉพาะ Admin/หน่วยกู้ภัยที่ล็อกอินแล้ว
      allow create: if request.resource.data.keys().hasAll(['lat', 'lng', 'status', 'resolved'])
                    && request.resource.data.lat is number
                    && request.resource.data.lng is number
                    && request.resource.data.status in
                       ['trapped', 'injured_severe', 'injured_minor', 'helping'];
      // resolve/acknowledge ทำได้เฉพาะ Admin ที่ล็อกอินแล้วเท่านั้น
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['resolved', 'resolvedAt', 'acknowledged']);
      allow delete: if false;
    }

    // ----- คำขอ "ขอจุดปลอดภัย" ของผู้ใช้ (มีชื่อ/เบอร์โทร) -----
    match /safe_requests/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      // ผู้ใช้อัปเดตสถานะเช็คอินของ "เอกสารตัวเอง" ได้โดยไม่ต้องล็อกอิน (รู้แค่ id ของตัวเอง)
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['checkedIn', 'checkInTime']);
      allow delete: if false;
    }

    // ----- รายงานพิกัด/สถานะที่ผู้ใช้แจ้งเอง (มีชื่อ/เบอร์โทร) -----
    match /status_reports/{id} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if false;
    }

    // ----- จุดสาธารณะ (ไม่มีชื่อ/เบอร์โทร) ใช้แสดงบน Dashboard สาธารณะ -----
    match /public_pins/{id} {
      allow read: if true; // ไม่มี PII เปิดอ่านสาธารณะได้อย่างปลอดภัย
      allow create: if true;
      allow update: if request.auth != null; // เฉพาะ Admin แก้สถานะ (เช่น resolve SOS)
      allow delete: if false;
    }

    // ----- ความจุปัจจุบันของแต่ละจุดปลอดภัย (ไม่มี PII) -----
    match /zone_state/{id} {
      allow read: if true;
      allow write: if true; // ต้องเปิดกว้างเพราะ transaction เพิ่มยอดจากฝั่ง client
    }

    // ----- ประวัติเหตุการณ์แผ่นดินไหว (ไม่มี PII) -----
    match /quake_events/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
