rules_version = '2';

// ============================================================================
// Firestore Security Rules — Plodpai Alert
//
// ระบบสิทธิ์ 3 ระดับ:
//   1) สาธารณะ (ไม่ล็อกอิน) — อ่าน public_pins, zone_state, quake_events, system ได้
//      (ไม่มี PII ในคอลเลกชันเหล่านี้เลย)
//   2) Staff (role = admin หรือ rescue) — อ่านข้อมูลเต็มรูปแบบ (มีชื่อ/เบอร์โทร) ได้
//      และรับเรื่อง/ปิดเคส SOS ได้
//   3) Admin เท่านั้น (role = admin) — จัดการบัญชีผู้ใช้ (roles) และเคลียร์ Dashboard ได้
//
// บทบาทของแต่ละคนเก็บไว้ในคอลเลกชัน roles/{uid} — ต้องสร้างเอกสาร roles/{uid}
// ของ Admin คนแรกด้วยตนเองผ่าน Firebase Console (ดูขั้นตอนใน README.md)
// ============================================================================

function isSignedIn() {
  return request.auth != null;
}

function myRole() {
  return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role;
}

function isStaff() {
  return isSignedIn() &&
    exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
    myRole() in ['admin', 'rescue'];
}

function isAdmin() {
  return isSignedIn() &&
    exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
    myRole() == 'admin';
}

service cloud.firestore {
  match /databases/{database}/documents {

    // ----- บทบาทผู้ใช้ (admin / rescue) — จัดการได้เฉพาะ Admin -----
    match /roles/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // ----- สถานะเคลียร์ Dashboard (ไม่มี PII เปิดอ่านสาธารณะได้) -----
    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ----- คำขอ SOS (มีชื่อ/เบอร์โทร) -----
    match /sos_alerts/{id} {
      allow read: if isStaff();
      allow create: if request.resource.data.keys().hasAll(['lat', 'lng', 'status', 'resolved'])
                    && request.resource.data.lat is number
                    && request.resource.data.lng is number
                    && request.resource.data.status in
                       ['trapped', 'injured_severe', 'injured_minor', 'helping'];
      allow update: if isStaff()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['resolved', 'resolvedAt', 'acknowledged']);
      allow delete: if isAdmin();
    }

    // ----- คำขอ "ขอจุดปลอดภัย" ของผู้ใช้ (มีชื่อ/เบอร์โทร) -----
    match /safe_requests/{id} {
      allow read: if isStaff();
      allow create: if true;
      // ผู้ใช้อัปเดตสถานะเช็คอินของ "เอกสารตัวเอง" ได้โดยไม่ต้องล็อกอิน (รู้แค่ id ของตัวเอง)
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['checkedIn', 'checkInTime']);
      allow delete: if isAdmin();
    }

    // ----- รายงานพิกัด/สถานะที่ผู้ใช้แจ้งเอง (มีชื่อ/เบอร์โทร) -----
    match /status_reports/{id} {
      allow read: if isStaff();
      allow create: if true;
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ----- จุดสาธารณะ (ไม่มีชื่อ/เบอร์โทร) ใช้แสดงบน Dashboard สาธารณะ -----
    match /public_pins/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if isStaff();
      allow delete: if isAdmin(); // ใช้ตอนกด "เคลียร์ Dashboard"
    }

    // ----- ความจุปัจจุบันของแต่ละจุดปลอดภัย (ไม่มี PII) -----
    match /zone_state/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if true; // transaction เพิ่มยอดจากฝั่ง client
      allow delete: if isAdmin(); // ใช้ตอนกด "เคลียร์ Dashboard"
    }

    // ----- ประวัติเหตุการณ์แผ่นดินไหว (ไม่มี PII) -----
    match /quake_events/{id} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
